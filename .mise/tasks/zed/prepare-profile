#!/bin/sh
#MISE description="Prepare the isolated Zed profile used by manual-test tasks"
#USAGE flag "--user-data-dir <user_data_dir>" help="Profile directory for the isolated Zed session" default="/tmp/zed-k8s-validation" env="ZED_USER_DATA_DIR"
set -eu

user_data_dir="${usage_user_data_dir:-$ZED_USER_DATA_DIR}"
settings_dir="$user_data_dir/config"
settings_path="$settings_dir/settings.json"

mkdir -p "$settings_dir"

if [ -f "$settings_path" ]; then
  exit 0
fi

cat >"$settings_path" <<'JSON'
{
  "session": {
    "trust_all_worktrees": true
  },
  "lsp": {
    "kubernetes-language-server": {
      "settings": {
        "kubernetes": {
          "logLevel": "debug"
        }
      }
    },
    "helm-language-server": {
      "settings": {
        "helm-ls": {
          "logLevel": "debug"
        }
      }
    }
  }
}
JSON
