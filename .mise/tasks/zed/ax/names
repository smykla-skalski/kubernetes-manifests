#!/bin/sh
#MISE description="List named accessibility elements from a chosen Zed window"
#USAGE flag "--process <process>" help="macOS Accessibility process name to inspect" default="zed" env="ZED_PROCESS"
#USAGE flag "--window-owner <window_owner>" help="Owner-name substring for native AX app matching" default="Zed Preview" env="ZED_WINDOW_OWNER"
#USAGE flag "--window-index <window_index>" help="1-based window index when no title filter is provided" default="1" env="ZED_WINDOW_INDEX"
#USAGE flag "--title-contains <title_contains>" help="Prefer the first window whose title contains this substring" env="ZED_WINDOW_TITLE_CONTAINS"
#USAGE flag "--contains <contains>" help="Only include names containing this substring"
set -eu

config_root="${MISE_CONFIG_ROOT:-$PWD}"
process="${usage_process:-$ZED_PROCESS}"
window_owner="${usage_window_owner:-$ZED_WINDOW_OWNER}"
window_index="${usage_window_index:-1}"
title_contains="${usage_title_contains-}"
name_filter="${usage_contains-}"

exec env \
  ZED_AX_PROCESS="$process" \
  ZED_WINDOW_OWNER="$window_owner" \
  ZED_AX_WINDOW_INDEX="$window_index" \
  ZED_AX_TITLE_CONTAINS="$title_contains" \
  ZED_AX_NAME_FILTER="$name_filter" \
  swift "$config_root/.mise/zed_ax_runtime.swift" names
