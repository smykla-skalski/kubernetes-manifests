#!/bin/sh
#MISE description="Seed a fresh isolated Zed profile from an existing profile's extension state"
#USAGE flag "--user-data-dir <user_data_dir>" help="Target profile directory for the isolated Zed session" default="/tmp/zed-k8s-validation-clean" env="ZED_USER_DATA_DIR"
#USAGE flag "--from-user-data-dir <from_user_data_dir>" help="Source profile directory to copy extension state from" default="/tmp/zed-k8s-validation"
set -eu

target_dir="${usage_user_data_dir:-/tmp/zed-k8s-validation-clean}"
source_dir="${usage_from_user_data_dir:-/tmp/zed-k8s-validation}"
source_extensions_dir="$source_dir/extensions"
if [ ! -d "$source_extensions_dir/installed" ]; then
  echo "source profile does not contain an installed extensions directory: $source_dir" >&2
  exit 1
fi

rm -rf "$target_dir"
mkdir -p "$target_dir/extensions/installed"
if [ -f "$source_extensions_dir/index.json" ]; then
  rsync -a "$source_extensions_dir/index.json" "$target_dir/extensions/index.json"
fi
rsync -a "$source_extensions_dir/installed/" "$target_dir/extensions/installed/"
mise run zed:prepare-profile --user-data-dir "$target_dir" >/dev/null
