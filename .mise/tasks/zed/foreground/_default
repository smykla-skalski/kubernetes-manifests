#!/bin/sh
#MISE description="Open Zed Preview in the isolated stateless profile and keep logs on stdout"
#USAGE flag "--user-data-dir <user_data_dir>" help="Profile directory for the isolated Zed session" default="/tmp/zed-k8s-validation" env="ZED_USER_DATA_DIR"
#USAGE arg "<path>" default="."
set -eu

user_data_dir="${usage_user_data_dir:-$ZED_USER_DATA_DIR}"
target="${usage_path:-.}"
repo_root="${MISE_PROJECT_ROOT:-${MISE_CONFIG_ROOT:-$PWD}}"
mise run zed:prepare-profile --user-data-dir "$user_data_dir" >/dev/null

case "$target" in
  .)
    set -- "$repo_root"
    ;;
  /*)
    set -- "$repo_root" "$target"
    ;;
  *)
    set -- "$repo_root" "$repo_root/$target"
    ;;
esac

if [ "${KUBERNETES_MANIFESTS_ZED_NEW_WINDOW:-0}" = "1" ]; then
  exec env ZED_STATELESS=1 "$ZED_CLI" --foreground --new --zed "$ZED_APP" --user-data-dir "$user_data_dir" "$@"
fi
exec env ZED_STATELESS=1 "$ZED_CLI" --foreground --zed "$ZED_APP" --user-data-dir "$user_data_dir" "$@"
