#!/bin/sh
#MISE description="Build extension.wasm for local dev-extension use"
#MISE depends=["rust:bootstrap"]
#MISE sources=["Cargo.toml", "Cargo.lock", "src/**/*.rs"]
#MISE outputs=["extension.wasm"]
#USAGE flag "--features <features>" help="Optional Cargo features to enable while building extension.wasm" default="" env="K8S_EXTENSION_FEATURES"
set -eu

cd "${MISE_CONFIG_ROOT:-$PWD}"
features="${usage_features:-${K8S_EXTENSION_FEATURES:-}}"

set -- cargo build --target wasm32-wasip2 --target-dir target
if [ -n "$features" ]; then
  set -- "$@" --features "$features"
fi
RUSTC_WRAPPER="" "$@"

crate_name="$(
  awk -F'"' '
    $0 == "[package]" { in_package = 1; next }
    /^\[/ { in_package = 0 }
    in_package && $1 ~ /^name = / { print $2; exit }
  ' Cargo.toml | tr '-' '_'
)"

artifact_path="target/wasm32-wasip2/debug/${crate_name}.wasm"
if [ ! -f "$artifact_path" ]; then
  printf >&2 'expected wasm artifact not found: %s\n' "$artifact_path"
  exit 1
fi

install -m 0644 "$artifact_path" extension.wasm
